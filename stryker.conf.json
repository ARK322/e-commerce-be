{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "off",
  "mutate": [
    "src/internal/buyers/payment/finalize-checkout-payment.ts",
    "src/internal/buyers/orders/fulfill-order.ts",
    "src/internal/buyers/orders/reserve-order-stock.ts"
  ],
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  }
}
