# Local geliştirme portu (frontend 3000'deyse 3001 kullan)
# Railway: PORT yazma veya 8080 yap — 3001 YAZMA (502 verir)
PORT=3001

# MongoDB bağlantı adresi
MONGO_URI=mongodb://localhost:27017/e-commerce

# JWT imzalama anahtarı (giriş, mail doğrulama, şifre sıfırlama token'ları)
JWT_SECRET=your-secret-key

# Gmail SMTP — normal Gmail şifresi değil, Google App Password kullan
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deko3dgpt1@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=deko3dgpt1@gmail.com

# Kullanıcının tarayıcıda açtığı frontend adresi (React/Next sitesi).
# Maildeki doğrulama ve şifre sıfırlama linkleri buraya gider — API adresi değil.
# Local test: frontend 3000'deyse http://localhost:3000
FRONTEND_URL=http://localhost:3000

# İlk owner admin (npm run seed:owner) — sadece local/ilk kurulum
SEED_OWNER_EMAIL=admin@example.com
SEED_OWNER_PASSWORD=your-secure-password
